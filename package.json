{
  "name": "ai-sdr-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/db/migrate.js && node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "worker": "tsx src/worker.ts",
    "instantly:create-kinta-campaign": "tsx src/tools/upsertKintaCampaign.ts",
    "instantly:deploy-personas": "tsx src/tools/deployPersonaCampaigns.ts",
    "agent:chat": "tsx src/tools/chatWithOutboundAgent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@slack/web-api": "^7.7.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
