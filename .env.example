NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_sdr_agent

# Claude / Anthropic
ANTHROPIC_API_KEY=
CLAUDE_FAST_MODEL=claude-haiku-4-5
CLAUDE_STRONG_MODEL=claude-haiku-4-5

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=

# Instantly
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=

# Apollo
APOLLO_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_HOT_REPLIES=agent-hot-replies
SLACK_CHANNEL_APPROVALS=agent-approvals
SLACK_CHANNEL_DAILY_DIGEST=agent-daily-digest
SLACK_CHANNEL_ERRORS=agent-errors
SLACK_CHANNEL_ANALYTICS=agent-analytics

# Workers
WORKER_POLL_INTERVAL_MS=2000
WORKER_CONCURRENCY=3
